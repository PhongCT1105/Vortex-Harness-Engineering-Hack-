# All keys are optional. Missing key = mock path = pipeline still runs end-to-end.

# Person A — Jua real weather
JUA_API_KEY=
# Optional if Jua provides a team-specific forecast endpoint
JUA_FORECAST_URL=
# Optional free-tier backup provider. Open-Meteo and wttr.in work with no key.
WEATHERAPI_KEY=

# Optional AI agents for scenario parsing and orchestration
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Person A — ClickHouse event log sink
CLICKHOUSE_HOST=
CLICKHOUSE_PORT=8443
CLICKHOUSE_USER=
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=default

# Person B — Airbyte / Slack send
AIRBYTE_API_KEY=
# Optional webhook/source endpoint for sending structured reports into Airbyte.
AIRBYTE_REPORT_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=slack#procurement
# From your Slack app's "Basic Information" page. Used to verify
# POST /slack/interactions requests (Approve button clicks). Optional —
# if unset, interaction requests are accepted unverified (dev/demo mode).
SLACK_SIGNING_SECRET=
# Public URL of this backend, e.g. https://stormops-api.onrender.com
# Set this as the Slack app's Interactivity Request URL + "/slack/interactions".
BACKEND_PUBLIC_URL=

# Orchestration
AUTO_EXECUTE_USD_LIMIT=100000
ACTIVE_MODEL=claude
# Runs the real weather -> ClickHouse -> context -> Claude -> dispatch pipeline on a schedule.
AUTO_PIPELINE_ENABLED=true
# Set true if you want one automatic run immediately when the backend starts.
AUTO_PIPELINE_RUN_ON_STARTUP=false

# Supply-chain weather monitor
# Uses Open-Meteo + free search context, refreshed in-memory on this cadence.
SUPPLY_CHAIN_WEATHER_REFRESH_HOURS=4

# CORS — origin of the Next.js frontend
FRONTEND_ORIGIN=http://localhost:3000
